{
    "name": "rjds/php-humanize",
    "description": "A PHP library to convert machine data into human-readable strings.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Rjds\\PhpHumanize\\": "src/"
        },
        "classmap": [
            "src/Formatter/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Rjds\\PhpHumanize\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ruben Eekhof",
            "email": "rubeneekhof@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpro/grumphp": "^1.13 || ^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.0",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "infection/infection": "^0.27 || ^0.32",
        "phpstan/phpstan-strict-rules": "^1.6 || ^2.0"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true,
            "infection/extension-installer": true
        }
    }
}
